# ==============================================================================
# پیکربندی متغیرهای محیطی سالن زیبایی پروانه
# Parvane Beauty Salon Environment Variables Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# پایگاه داده (PostgreSQL Configuration)
# ------------------------------------------------------------------------------
# آدرس سرور پایگاه داده (مثلا postgres در داکر یا localhost در لوکال)
DATABASE_HOST=localhost
# پورت اتصال به پایگاه داده (پیش‌فرض ۵۴۳۲)
DATABASE_PORT=5432
# نام کاربری پایگاه داده
DATABASE_USER=postgres
# رمز عبور پایگاه داده
DATABASE_PASSWORD=parvane2024
# نام دیتابیس برنامه
DATABASE_NAME=parvane_salon
# همگام‌سازی خودکار اسکیمای دیتابیس (در محیط پروداکشن روی false بگذارید)
DATABASE_SYNCHRONIZE=true
# فعال‌سازی پروتکل امن دیتابیس SSL
DATABASE_SSL=false

# ------------------------------------------------------------------------------
# امنیت و توکن (JWT Security Configuration)
# ------------------------------------------------------------------------------
# کلید امنیتی امضای توکن‌های JWT (حتما یک رشته طولانی و تصادفی قرار دهید)
JWT_SECRET=parvane_super_secret_jwt_key_2024
# مدت زمان انقضای توکن دسترسی
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# ردیس (Redis Configuration - Used for Caching and Throttling)
# ------------------------------------------------------------------------------
# آدرس سرور ردیس
REDIS_HOST=localhost
# پورت سرور ردیس
REDIS_PORT=6379
# رمز عبور سرور ردیس (در صورت نیاز)
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# تنظیمات کلی اپلیکیشن (General App Configuration)
# ------------------------------------------------------------------------------
# پورت اجرای سرور بکند
PORT=3000
# محیط برنامه (production یا development)
NODE_ENV=development
# آدرس اینترنتی کامل سرور بکند
APP_URL=http://localhost:3000
# دامنه‌های مجاز برای دسترسی CORS (با کاما جدا شوند، یا * برای همه دامنه‌ها)
ALLOWED_ORIGINS=*

# ------------------------------------------------------------------------------
# آپلود فایل (File Upload Configuration)
# ------------------------------------------------------------------------------
# پوشه ذخیره‌سازی تصاویر آپلود شده
UPLOAD_DIR=./uploads
# حداکثر حجم فایل آپلودی به بایت (مثلا ۱۰ مگابایت)
MAX_FILE_SIZE=10485760

# ------------------------------------------------------------------------------
# سیستم وفاداری مشتریان (Loyalty Points Configuration)
# ------------------------------------------------------------------------------
# امتیاز دریافتی بابت هر رزرو موفق انجام شده
POINTS_PER_APPOINTMENT=100
# امتیاز دریافتی بابت ثبت هر نظر روی رزرو
POINTS_PER_REVIEW=50
